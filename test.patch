+    def _candidate_school_urls(school_url: str) -> list[str]:
+        parsed = urlparse(school_url)
+        base = urlunparse((parsed.scheme, parsed.netloc, "", "", "", ""))
+        path = parsed.path or "/"
+        query = parsed.query
+        fragment = parsed.fragment
