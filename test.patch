+        # Some listing links include '/reports/' even though detail pages live at root.
+        if path.startswith("/reports/"):
+            alt_path = path[len("/reports") :]
+            alt_url = urlunparse((parsed.scheme, parsed.netloc, alt_path, "", query, fragment))
